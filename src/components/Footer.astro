<footer class="border-t border-kobi-border py-12">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div>
        <span class="text-xl font-bold text-white"
          >Kobi <span class="text-emerald-500">কবি</span></span
        >
        <p class="mt-1 text-sm text-kobi-muted" data-i18n="footer.tagline">Code like a poet</p>
      </div>

      <div class="flex gap-6 text-sm text-kobi-muted">
        <a href="#features" class="transition hover:text-white" data-i18n="nav.features">Features</a>
        <a href="#pricing" class="transition hover:text-white" data-i18n="nav.pricing">Pricing</a>
        <a href="#download" class="transition hover:text-white" data-i18n="nav.download">Download</a>
        <a
          href="https://app.kobidev.com/login"
          class="transition hover:text-white" data-i18n="footer.login">Login</a
        >
      </div>

      <div class="text-sm text-kobi-muted">
        <span data-i18n="footer.made">Made for Bangladesh</span>
        <span class="mx-1">·</span>
        <span data-i18n="footer.built">Built in Germany</span>
      </div>
    </div>
    <div class="mt-8 text-center text-xs text-kobi-muted/50">
      &copy; {new Date().getFullYear()} <span data-i18n="footer.copyright">Kobi. All rights reserved.</span>
    </div>
  </div>
</footer>
