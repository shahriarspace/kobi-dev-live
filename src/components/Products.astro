    name: "Kobi SMS",
    descKey: "products.sms.desc",
    desc: "AI via SMS — no internet needed. Text a question, get an answer. Works on any phone. Bangla and Banglish supported.",
    statusKey: "products.sms.status",
    status: "Coming Soon",
    live: false,
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-6 18h6"/></svg>`,
