---

<section id="products" class="py-20 md:py-28 border-b border-kobi-border">
  <div class="mx-auto max-w-6xl px-4">
    <div class="fade-in mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="products.title">
        One platform, six AI tools
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="products.subtitle">
        Everything a Bangladeshi professional needs — coding, communication, career, freelancing. One credit wallet powers them all.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {products.map((product, i) => (
        <div class={`fade-in rounded-xl border p-6 transition-all ${product.live ? 'border-emerald-500/50 bg-emerald-500/5' : 'border-kobi-border bg-kobi-surface'} ${i === 0 ? 'md:col-span-2 lg:col-span-1' : ''}`}>
          <div class="mb-4 flex items-start justify-between">
            <div class={`flex h-12 w-12 items-center justify-center rounded-lg ${product.live ? 'bg-emerald-500/10 text-emerald-400' : 'bg-kobi-border/50 text-kobi-muted'}`}>
              <Fragment set:html={product.icon} />
            </div>
            <span class={`rounded-full px-2.5 py-1 text-xs font-semibold ${product.live ? 'bg-emerald-500/20 text-emerald-400' : 'bg-kobi-border text-kobi-muted'}`} data-i18n={product.statusKey}>
              {product.status}
            </span>
          </div>
          <h3 class="mb-2 text-xl font-bold text-white" data-i18n={product.nameKey}>{product.name}</h3>
          <p class="mb-4 text-sm leading-relaxed text-kobi-muted" data-i18n={product.descKey}>
            {product.desc}
          </p>
          {product.live ? (
            <a
              href={product.href}
              class="inline-flex items-center gap-1 text-sm font-semibold text-emerald-400 transition hover:text-emerald-300"
              data-i18n="products.try"
            >
              Try now &rarr;
            </a>
          ) : (
            <span class="text-xs text-kobi-muted" data-i18n="products.notify">
              Notify me when available
            </span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
