    nameKey: "products.code.name",
    name: "Kobi Code",
    descKey: "products.code.desc",
    desc: "AI coding assistant for VS Code. Inline completions, chat, agent mode, BD templates. The GitHub Copilot alternative for Bangladesh.",
    statusKey: "products.code.status",
    status: "Live",
    live: true,
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`,
