---
const rows = [
  { key: "compare.row.price",       label: "Price",                kobi: "compare.kobi.price",       copilot: "compare.copilot.price",       kobiWin: true  },
  { key: "compare.row.payment",     label: "Payment",              kobi: "compare.kobi.payment",     copilot: "compare.copilot.payment",     kobiWin: true  },
  { key: "compare.row.completions", label: "Inline completions",   kobi: "compare.kobi.completions", copilot: "compare.copilot.completions", kobiWin: false },
  { key: "compare.row.chat",        label: "AI chat",              kobi: "compare.kobi.chat",        copilot: "compare.copilot.chat",        kobiWin: false },
  { key: "compare.row.agent",       label: "Agent mode",           kobi: "compare.kobi.agent",       copilot: "compare.copilot.agent",       kobiWin: false },
  { key: "compare.row.models",      label: "AI models",            kobi: "compare.kobi.models",      copilot: "compare.copilot.models",      kobiWin: false },
  { key: "compare.row.support",     label: "Local support",        kobi: "compare.kobi.support",     copilot: "compare.copilot.support",     kobiWin: true  },
  { key: "compare.row.intlcard",    label: "International card",   kobi: "compare.kobi.intlcard",    copilot: "compare.copilot.intlcard",    kobiWin: true  },
];
---

<section id="comparison" class="py-20 md:py-28">
  <div class="mx-auto max-w-4xl px-4">
    <div class="fade-in mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="compare.title">
        Kobi vs GitHub Copilot
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="compare.subtitle">
        Same AI power, built for Bangladesh. See how they compare.
      </p>
    </div>

    <div class="fade-in overflow-hidden rounded-xl border border-kobi-border">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-kobi-border bg-kobi-surface">
            <th class="px-6 py-4 font-semibold text-kobi-muted" data-i18n="compare.col.feature">Feature</th>
            <th class="px-6 py-4 text-center font-semibold text-emerald-500">Kobi</th>
            <th class="px-6 py-4 text-center font-semibold text-kobi-muted">GitHub Copilot</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class:list={["border-b border-kobi-border last:border-b-0 transition", i % 2 === 0 ? "bg-kobi-bg" : "bg-kobi-surface/50"]}>
              <td class="px-6 py-4 font-medium text-white" data-i18n={row.key}>{row.label}</td>
              <td class="px-6 py-4 text-center">
                <span class:list={["inline-block rounded-full px-3 py-1 text-xs font-semibold", row.kobiWin ? "bg-emerald-500/10 text-emerald-400" : "text-kobi-muted"]} data-i18n={row.kobi}>
                </span>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="inline-block rounded-full px-3 py-1 text-xs font-semibold text-kobi-muted" data-i18n={row.copilot}>
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="fade-in mt-8 text-center">
      <a href="https://app.kobidev.com/signup" class="inline-block rounded-lg bg-emerald-500 px-8 py-3 text-sm font-semibold text-black transition hover:bg-emerald-400" data-i18n="compare.cta">
        Try Kobi free →
      </a>
    </div>
  </div>
</section>
