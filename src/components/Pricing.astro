---

<section id="pricing" class="py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-4">
    <div class="fade-in mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="pricing.title">
        Simple pricing in BDT
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="pricing.subtitle">
        Pay with bKash — no international card needed. Cancel anytime.
      </p>
    </div>

    <!-- Mobile: scrollable, Desktop: grid -->
    <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory md:grid md:grid-cols-4 md:overflow-visible md:pb-0 lg:grid-cols-7">
      {
        plans.map((plan) => (
          <div
            class:list={[
              "fade-in relative flex-shrink-0 w-[280px] snap-center rounded-xl p-6 transition md:w-auto",
              plan.popular
                ? "border-2 border-emerald-500 bg-emerald-500/5 shadow-lg shadow-emerald-500/10"
                : "border border-kobi-border bg-kobi-surface",
            ]}
          >
            {/* Most popular badge */}
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-4 py-1 text-xs font-semibold text-black whitespace-nowrap" data-i18n="pricing.popular">
                Most popular
              </div>
            )}

            {/* Plan name + model badge */}
            <div class="flex items-center gap-2 mb-3">
              <h3 class="text-lg font-semibold text-white" data-i18n={plan.nameKey}>{plan.name}</h3>
              <Fragment set:html={plan.model === "haiku" ? haikuBadge : sonnetBadge} />
            </div>

            {/* Price */}
            <div class="mb-5">
              {plan.launchOffer ? (
                <div>
                  <span class="text-lg text-kobi-muted line-through">{plan.launchOffer.original}</span>
                  <span class="text-3xl font-bold text-emerald-400 ml-1">{plan.launchOffer.price}</span>
                  <span class="text-kobi-muted text-sm">{plan.period}</span>
                  <div class="mt-1">
                    <span class="inline-block rounded-full bg-emerald-500/20 px-2.5 py-0.5 text-xs font-semibold text-emerald-400" data-i18n={plan.launchOffer.labelKey}>
                      {plan.launchOffer.label}
                    </span>
                  </div>
                </div>
              ) : (
                <div>
                  <span class="text-3xl font-bold text-white" data-i18n={plan.priceKey}>{plan.price}</span>
                  {plan.period && <span class="text-kobi-muted text-sm">{plan.period}</span>}
                </div>
              )}
            </div>

            {/* Features */}
            <ul class="mb-6 space-y-2">
              {plan.features.map((f) => (
                <li class:list={[
                  "flex items-start gap-2 text-sm",
                  f.enabled ? "text-kobi-muted" : "text-kobi-muted/50",
                ]}>
                  <Fragment set:html={f.enabled ? checkSvg : xSvg} />
                  <span data-i18n={f.i18nKey}>{f.text}</span>
                </li>
              ))}
            </ul>

            {/* CTA */}
            <a
              href={plan.ctaUrl}
              class:list={[
                "block w-full rounded-lg py-2.5 text-center text-sm font-semibold transition",
                plan.popular
                  ? "bg-emerald-500 text-black hover:bg-emerald-400"
                  : plan.launchOffer
                    ? "bg-emerald-500 text-black hover:bg-emerald-400"
                    : "border border-kobi-border text-white hover:bg-kobi-surface hover:border-kobi-muted",
              ]}
              data-i18n={plan.ctaKey}
            >
              {plan.ctaText}
            </a>
          </div>
        ))
      }
    </div>

    <div class="fade-in mt-10 text-center">
      <p class="text-sm text-kobi-muted" data-i18n="pricing.pay">Pay with bKash</p>
    </div>
  </div>
</section>
