---

<section id="pricing" class="py-20 md:py-28 border-b border-kobi-border">
  <div class="mx-auto max-w-6xl px-4">
    <div class="fade-in mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="pricing.title">
        Simple credit pricing in BDT
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="pricing.subtitle">
        1 Kobi Credit = ৳1 BDT. Buy credits, use across all Kobi apps. Pay with bKash or Nagad.
      </p>
    </div>

    <!-- Monthly Plans heading -->
    <h3 class="fade-in mb-6 text-xl font-semibold text-white" data-i18n="pricing.monthly">Monthly Plans</h3>

    <!-- Plan cards -->
    <div class="fade-in mb-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {plans.map((plan) => (
        <div class={`relative rounded-xl border p-6 ${plan.popular ? 'border-emerald-500 bg-emerald-500/5' : 'border-kobi-border bg-kobi-surface'}`}>
          {plan.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-3 py-0.5 text-xs font-semibold text-black" data-i18n="pricing.popular">
              Most popular
            </div>
          )}
          <div class="mb-1 text-sm font-semibold text-kobi-muted" data-i18n={plan.nameKey}>{plan.name}</div>
          <div class="mb-1 text-3xl font-black text-white" data-i18n={plan.priceKey}>{plan.price}</div>
          <div class="mb-1 text-sm font-semibold text-emerald-400" data-i18n={plan.creditsKey}>{plan.credits}</div>
          <div class="mb-4 text-xs text-kobi-muted" data-i18n={plan.detailKey}>{plan.detail}</div>
          <a
            href={plan.href}
            class={`block rounded-lg py-2.5 text-center text-sm font-semibold transition ${plan.popular ? 'bg-emerald-500 text-black hover:bg-emerald-400' : 'border border-kobi-border text-white hover:border-kobi-muted hover:bg-kobi-surface'}`}
            data-i18n={plan.ctaKey}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Top-up Packs heading -->
    <h3 class="fade-in mb-6 text-xl font-semibold text-white" data-i18n="pricing.topup">Top-up Packs</h3>

    <!-- Top-up cards -->
    <div class="fade-in mb-12 grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-5">
      {topups.map((pack) => (
        <div class="rounded-xl border border-kobi-border bg-kobi-surface p-4 text-center">
          <div class="mb-1 text-sm font-semibold text-kobi-muted" data-i18n={pack.nameKey}>{pack.name}</div>
          <div class="mb-1 text-2xl font-black text-white" data-i18n={pack.priceKey}>{pack.price}</div>
          <div class="text-sm text-emerald-400" data-i18n={pack.creditsKey}>{pack.credits}</div>
        </div>
      ))}
    </div>

    <!-- Credits per action -->
    <div class="fade-in">
      <h3 class="mb-4 text-lg font-semibold text-white" data-i18n="pricing.usage.title">Credits per action</h3>
      <div class="overflow-hidden rounded-xl border border-kobi-border">
        <table class="w-full text-sm">
          <tbody>
            {usageRows.map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-kobi-surface' : 'bg-kobi-bg'}>
                <td class="px-4 py-3 text-kobi-text" data-i18n={row.actionKey}>{row.action}</td>
                <td class="px-4 py-3 text-right font-semibold text-emerald-400" data-i18n={row.costKey}>{row.cost}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Footer notes -->
    <div class="fade-in mt-8 text-center">
      <p class="text-sm text-emerald-400 font-semibold mb-2" data-i18n="pricing.claude">
        Powered by Anthropic Claude
      </p>
      <p class="text-sm text-kobi-muted" data-i18n="pricing.nocard">
        No card needed. Pay with bKash or Nagad. Credits never expire on paid plans.
      </p>
    </div>
  </div>
</section>
