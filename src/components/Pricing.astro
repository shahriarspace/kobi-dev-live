---
---

<section id="pricing" class="py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-4">
    <div class="fade-in mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="pricing.title">
        Simple pricing in BDT
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="pricing.subtitle">
        Pay with bKash — no international card needed. Cancel anytime.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      <!-- Free -->
      <div class="fade-in relative rounded-xl border border-kobi-border bg-kobi-surface p-7 transition">
        <h3 class="mb-2 text-xl font-semibold text-white" data-i18n="pricing.free.name">Free</h3>
        <div class="mb-5">
          <span class="text-4xl font-bold text-white">০</span>
          <span class="text-kobi-muted">/month</span>
        </div>
        <ul class="mb-7 space-y-2.5">
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.free.f1">200 completions/month</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.free.f2">20 chat messages/month</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted/50">
            <svg class="h-4 w-4 flex-shrink-0 text-kobi-muted/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <span data-i18n="pricing.free.f3">No agent runs</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.free.f4">Community support</span>
          </li>
        </ul>
        <a href="https://app.kobidev.com/signup?plan=free" class="block w-full rounded-lg border border-kobi-border py-2.5 text-center text-sm font-semibold text-white transition hover:bg-kobi-surface hover:border-kobi-muted" data-i18n="pricing.free.cta">
          Start free
        </a>
      </div>

      <!-- Basic (popular) -->
      <div class="fade-in relative rounded-xl border border-emerald-500 bg-emerald-500/5 p-7 shadow-lg shadow-emerald-500/10 transition">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-4 py-1 text-xs font-semibold text-black" data-i18n="pricing.popular">
          Most popular
        </div>
        <h3 class="mb-2 text-xl font-semibold text-white" data-i18n="pricing.basic.name">Basic</h3>
        <div class="mb-5">
          <span class="text-4xl font-bold text-white">৳400</span>
          <span class="text-kobi-muted">/month</span>
        </div>
        <ul class="mb-7 space-y-2.5">
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.basic.f1">2,000 completions/month</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.basic.f2">300 chat messages/month</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted/50">
            <svg class="h-4 w-4 flex-shrink-0 text-kobi-muted/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <span data-i18n="pricing.basic.f3">No agent runs</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.basic.f4">Email support</span>
          </li>
        </ul>
        <a href="https://app.kobidev.com/signup?plan=basic" class="block w-full rounded-lg bg-emerald-500 py-2.5 text-center text-sm font-semibold text-black transition hover:bg-emerald-400" data-i18n="pricing.basic.cta">
          Get Basic
        </a>
      </div>

      <!-- Pro -->
      <div class="fade-in relative rounded-xl border border-kobi-border bg-kobi-surface p-7 transition">
        <h3 class="mb-2 text-xl font-semibold text-white" data-i18n="pricing.pro.name">Pro</h3>
        <div class="mb-5">
          <span class="text-4xl font-bold text-white">৳900</span>
          <span class="text-kobi-muted">/month</span>
        </div>
        <ul class="mb-7 space-y-2.5">
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.pro.f1">Unlimited completions</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.pro.f2">700 chat messages/month</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted/50">
            <svg class="h-4 w-4 flex-shrink-0 text-kobi-muted/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <span data-i18n="pricing.pro.f3">No agent runs</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.pro.f4">Priority support</span>
          </li>
        </ul>
        <a href="https://app.kobidev.com/signup?plan=pro" class="block w-full rounded-lg border border-kobi-border py-2.5 text-center text-sm font-semibold text-white transition hover:bg-kobi-surface hover:border-kobi-muted" data-i18n="pricing.pro.cta">
          Get Pro
        </a>
      </div>

      <!-- Power -->
      <div class="fade-in relative rounded-xl border border-kobi-border bg-kobi-surface p-7 transition">
        <h3 class="mb-2 text-xl font-semibold text-white" data-i18n="pricing.power.name">Power</h3>
        <div class="mb-5">
          <span class="text-4xl font-bold text-white">৳2,000</span>
          <span class="text-kobi-muted">/month</span>
        </div>
        <ul class="mb-7 space-y-2.5">
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.power.f1">Unlimited completions</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.power.f2">1,500 chat messages/month</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.power.f3">30 agent runs/month</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.power.f4">Priority support</span>
          </li>
        </ul>
        <a href="https://app.kobidev.com/signup?plan=power" class="block w-full rounded-lg border border-kobi-border py-2.5 text-center text-sm font-semibold text-white transition hover:bg-kobi-surface hover:border-kobi-muted" data-i18n="pricing.power.cta">
          Get Power
        </a>
      </div>
    </div>

    <!-- More plans note -->
    <div class="fade-in mt-8 text-center">
      <p class="text-sm text-kobi-muted">
        <span data-i18n="pricing.more">Also available: Starter (৳150), Business (৳5,000), and Enterprise (custom).</span>{" "}
        <a href="https://app.kobidev.com/payment" class="text-emerald-400 hover:underline" data-i18n="pricing.seeAll">See all plans →</a>
      </p>
      <p class="mt-4 text-sm text-kobi-muted" data-i18n="pricing.pay">Pay with bKash</p>
    </div>
  </div>
</section>
