---
const plans = [
  {
    name: "Free",
    price: "০",
    priceSuffix: "/month",
    features: [
      "50 requests/month",
      "Inline completions",
      "Basic AI suggestions",
      "Community support",
    ],
    cta: "Start free",
    href: "https://app.kobidev.com/signup?plan=free",
    popular: false,
  },
  {
    name: "Basic",
    price: "৳500",
    priceSuffix: "/month",
    features: [
      "500 requests/month",
      "Inline completions",
      "AI chat panel",
      "Email support",
    ],
    cta: "Get Basic",
    href: "https://app.kobidev.com/signup?plan=basic",
    popular: true,
  },
  {
    name: "Pro",
    price: "৳1,200",
    priceSuffix: "/month",
    features: [
      "2,000 requests/month",
      "Inline completions",
      "AI chat + agent mode",
      "Priority support",
    ],
    cta: "Get Pro",
    href: "https://app.kobidev.com/signup?plan=pro",
    popular: false,
  },
];
---

<section id="pricing" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="fade-in mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">
        Simple pricing in BDT
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted">
        Pay with bKash — no international card needed. Cancel anytime.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {
        plans.map((plan) => (
          <div
            class:list={[
              "fade-in relative rounded-xl border p-8 transition",
              plan.popular
                ? "border-emerald-500 bg-emerald-500/5 shadow-lg shadow-emerald-500/10"
                : "border-kobi-border bg-kobi-surface",
            ]}
          >
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-4 py-1 text-xs font-semibold text-black">
                Most popular
              </div>
            )}
            <h3 class="mb-2 text-xl font-semibold text-white">{plan.name}</h3>
            <div class="mb-6">
              <span class="text-4xl font-bold text-white">{plan.price}</span>
              <span class="text-kobi-muted">{plan.priceSuffix}</span>
            </div>
            <ul class="mb-8 space-y-3">
              {plan.features.map((feature) => (
                <li class="flex items-center gap-2 text-kobi-muted">
                  <svg
                    class="h-5 w-5 flex-shrink-0 text-emerald-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
            <a
              href={plan.href}
              class:list={[
                "block w-full rounded-lg py-3 text-center font-semibold transition",
                plan.popular
                  ? "bg-emerald-500 text-black hover:bg-emerald-400"
                  : "border border-kobi-border text-white hover:bg-kobi-surface hover:border-kobi-muted",
              ]}
            >
              {plan.cta}
            </a>
            <p class="mt-4 text-center text-sm text-kobi-muted">
              Pay with bKash
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
