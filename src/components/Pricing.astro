---
---

<section id="pricing" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="fade-in mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="pricing.title">
        Simple pricing in BDT
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="pricing.subtitle">
        Pay with bKash — no international card needed. Cancel anytime.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      <!-- Free -->
      <div class="fade-in relative rounded-xl border border-kobi-border bg-kobi-surface p-8 transition">
        <h3 class="mb-2 text-xl font-semibold text-white" data-i18n="pricing.free.name">Free</h3>
        <div class="mb-6">
          <span class="text-4xl font-bold text-white">০</span>
          <span class="text-kobi-muted">/month</span>
        </div>
        <ul class="mb-8 space-y-3">
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.free.f1">50 requests/month</span>
          </li>
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.free.f2">Inline completions</span>
          </li>
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.free.f3">Basic AI suggestions</span>
          </li>
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.free.f4">Community support</span>
          </li>
        </ul>
        <a href="https://app.kobidev.com/signup?plan=free" class="block w-full rounded-lg border border-kobi-border py-3 text-center font-semibold text-white transition hover:bg-kobi-surface hover:border-kobi-muted" data-i18n="pricing.free.cta">
          Start free
        </a>
        <p class="mt-4 text-center text-sm text-kobi-muted" data-i18n="pricing.pay">Pay with bKash</p>
      </div>

      <!-- Basic (popular) -->
      <div class="fade-in relative rounded-xl border border-emerald-500 bg-emerald-500/5 p-8 shadow-lg shadow-emerald-500/10 transition">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-4 py-1 text-xs font-semibold text-black" data-i18n="pricing.popular">
          Most popular
        </div>
        <h3 class="mb-2 text-xl font-semibold text-white" data-i18n="pricing.basic.name">Basic</h3>
        <div class="mb-6">
          <span class="text-4xl font-bold text-white">৳500</span>
          <span class="text-kobi-muted">/month</span>
        </div>
        <ul class="mb-8 space-y-3">
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.basic.f1">500 requests/month</span>
          </li>
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.basic.f2">Inline completions</span>
          </li>
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.basic.f3">AI chat panel</span>
          </li>
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.basic.f4">Email support</span>
          </li>
        </ul>
        <a href="https://app.kobidev.com/signup?plan=basic" class="block w-full rounded-lg bg-emerald-500 py-3 text-center font-semibold text-black transition hover:bg-emerald-400" data-i18n="pricing.basic.cta">
          Get Basic
        </a>
        <p class="mt-4 text-center text-sm text-kobi-muted" data-i18n="pricing.pay">Pay with bKash</p>
      </div>

      <!-- Pro -->
      <div class="fade-in relative rounded-xl border border-kobi-border bg-kobi-surface p-8 transition">
        <h3 class="mb-2 text-xl font-semibold text-white" data-i18n="pricing.pro.name">Pro</h3>
        <div class="mb-6">
          <span class="text-4xl font-bold text-white">৳1,200</span>
          <span class="text-kobi-muted">/month</span>
        </div>
        <ul class="mb-8 space-y-3">
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.pro.f1">2,000 requests/month</span>
          </li>
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.pro.f2">Inline completions</span>
          </li>
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.pro.f3">AI chat + agent mode</span>
          </li>
          <li class="flex items-center gap-2 text-kobi-muted">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="pricing.pro.f4">Priority support</span>
          </li>
        </ul>
        <a href="https://app.kobidev.com/signup?plan=pro" class="block w-full rounded-lg border border-kobi-border py-3 text-center font-semibold text-white transition hover:bg-kobi-surface hover:border-kobi-muted" data-i18n="pricing.pro.cta">
          Get Pro
        </a>
        <p class="mt-4 text-center text-sm text-kobi-muted" data-i18n="pricing.pay">Pay with bKash</p>
      </div>
    </div>
  </div>
</section>
