  name: string;
  nameKey: string;
  price: string;
  priceKey: string;
  period: string;
  model: string; // "haiku" | "sonnet"
  features: PlanFeature[];
  ctaText: string;
  ctaKey: string;
  ctaUrl: string;
  popular?: boolean;
  launchOffer?: { original: string; price: string; label: string; labelKey: string };
  enterprise?: boolean;
}

