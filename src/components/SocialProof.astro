<section id="social-proof" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="fade-in text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="social.title">
        Trusted by developers across Bangladesh
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="social.subtitle">
        Join a growing community of Bangladeshi developers coding with AI.
      </p>

      <!-- Placeholder: stats or testimonials will be added as users come in -->
      <div class="mt-12 grid gap-6 sm:grid-cols-3">
        <div class="fade-in rounded-xl border border-kobi-border bg-kobi-surface p-6">
          <p class="text-3xl font-bold text-emerald-500">৳150</p>
          <p class="mt-2 text-sm text-kobi-muted" data-i18n="social.stat1">Starting price per month</p>
        </div>
        <div class="fade-in rounded-xl border border-kobi-border bg-kobi-surface p-6">
          <p class="text-3xl font-bold text-emerald-500">30 min</p>
          <p class="mt-2 text-sm text-kobi-muted" data-i18n="social.stat2">Average activation time</p>
        </div>
        <div class="fade-in rounded-xl border border-kobi-border bg-kobi-surface p-6">
          <p class="text-3xl font-bold text-emerald-500">7</p>
          <p class="mt-2 text-sm text-kobi-muted" data-i18n="social.stat3">Plans to fit every budget</p>
        </div>
      </div>

      <!-- Testimonial placeholder -->
      <p class="mt-10 text-sm text-kobi-muted/50 italic">
        Testimonials coming soon as our community grows.
      </p>
    </div>
  </div>
</section>
