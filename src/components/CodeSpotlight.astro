---
import CodeAnimation from "./CodeAnimation";
---

<section id="spotlight" class="py-20 md:py-28 border-b border-kobi-border" style="background: linear-gradient(180deg, #064e3b08 0%, #0a0a0a 100%);">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Left: Info -->
      <div class="fade-in">
        <div class="mb-2 inline-block rounded-full bg-emerald-500/20 px-3 py-1 text-xs font-semibold text-emerald-400">
          LIVE NOW
        </div>
        <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="spotlight.title">
          Kobi Code — live now
        </h2>
        <p class="mb-8 text-lg text-kobi-muted" data-i18n="spotlight.subtitle">
          AI coding assistant for VS Code. Inline completions, chat panel, agent mode, BD templates. Try it in your browser right now.
        </p>

        <ul class="mb-8 space-y-3">
          <li class="flex items-center gap-3 text-sm text-kobi-text">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="spotlight.f1">Inline completions as you type</span>
          </li>
          <li class="flex items-center gap-3 text-sm text-kobi-text">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="spotlight.f2">AI chat panel in VS Code</span>
          </li>
          <li class="flex items-center gap-3 text-sm text-kobi-text">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="spotlight.f3">Agent mode for multi-file tasks</span>
          </li>
          <li class="flex items-center gap-3 text-sm text-kobi-text">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="spotlight.f4">BD templates: bKash, Nagad, NID + more</span>
          </li>
          <li class="flex items-center gap-3 text-sm text-kobi-text">
            <svg class="h-5 w-5 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="spotlight.f5">Web chat — works on phone</span>
          </li>
        </ul>

        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href="https://chat.kobidev.com"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg bg-emerald-500 px-6 py-3 text-center font-semibold text-black transition hover:bg-emerald-400"
            data-i18n="spotlight.try"
          >
            Open Kobi Web Chat &rarr;
          </a>
          <a
            href="https://app.kobidev.com/signup"
            class="rounded-lg border border-kobi-border px-6 py-3 text-center font-semibold text-white transition hover:border-kobi-muted hover:bg-kobi-surface"
            data-i18n="spotlight.install"
          >
            Install VS Code Extension
          </a>
        </div>
        <p class="mt-3 text-sm text-kobi-muted" data-i18n="spotlight.note">
          Free tier included · No card needed
        </p>
      </div>

      <!-- Right: Code animation + chat mockup -->
      <div class="fade-in space-y-6">
        <CodeAnimation client:load />

        <!-- Mini web chat mockup -->
        <div class="mx-auto max-w-lg rounded-xl border border-kobi-border bg-kobi-surface overflow-hidden shadow-2xl">
          <div class="flex items-center gap-2 px-4 py-2.5 bg-[#111] border-b border-kobi-border">
            <div class="flex gap-1.5">
              <span class="w-3 h-3 rounded-full bg-red-500/40"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/40"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/40"></span>
            </div>
            <span class="text-xs text-kobi-muted ml-2">chat.kobidev.com</span>
          </div>
          <div class="p-4 space-y-3">
            <div class="flex justify-end">
              <div class="bg-emerald-600 text-white px-3 py-2 rounded-2xl rounded-br-md text-xs max-w-[80%]">
                How do I integrate bKash payment in Laravel?
              </div>
            </div>
            <div class="flex justify-start">
              <div class="bg-[#1a1a1a] border border-kobi-border px-3 py-2 rounded-2xl rounded-bl-md text-xs text-kobi-text max-w-[80%]">
                <div class="bg-[#111] rounded-lg p-2 font-mono text-[10px] text-emerald-400">
                  Route::post(<span class="text-amber-400">'/bkash/pay'</span>,<br>
                  &nbsp;&nbsp;[BkashController::class, <span class="text-amber-400">'create'</span>]);
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
