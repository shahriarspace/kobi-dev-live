---
import CodeAnimation from "./CodeAnimation";
---

<section id="spotlight" class="py-20 md:py-28 border-b border-kobi-border" style="background: linear-gradient(180deg, #064e3b08 0%, #0a0a0a 100%);">
  <div class="mx-auto max-w-6xl px-4">
    <!-- Section header -->
    <div class="fade-in mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="demo.title">
        See Kobi in action
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="demo.subtitle">
        Six AI tools, one platform. Click a product to see how it works.
      </p>
    </div>

    <!-- Product tabs -->
    <div class="fade-in mb-10 flex flex-wrap justify-center gap-2">
      <button class="demo-tab active rounded-full border border-emerald-500/50 bg-emerald-500/10 px-4 py-2 text-sm font-semibold text-emerald-400 transition hover:bg-emerald-500/20" data-tab="chat">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/></svg>
          <span data-i18n="demo.tab.chat">Chat</span>
        </span>
      </button>
      <button class="demo-tab rounded-full border border-kobi-border px-4 py-2 text-sm font-semibold text-kobi-muted transition hover:border-kobi-muted hover:text-kobi-text" data-tab="sms">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-6 18h6"/></svg>
          <span data-i18n="demo.tab.sms">SMS</span>
        </span>
      </button>
      <button class="demo-tab rounded-full border border-kobi-border px-4 py-2 text-sm font-semibold text-kobi-muted transition hover:border-kobi-muted hover:text-kobi-text" data-tab="cv">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
          <span data-i18n="demo.tab.cv">CV</span>
        </span>
      </button>
      <button class="demo-tab rounded-full border border-kobi-border px-4 py-2 text-sm font-semibold text-kobi-muted transition hover:border-kobi-muted hover:text-kobi-text" data-tab="interview">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/></svg>
          <span data-i18n="demo.tab.interview">Interview</span>
        </span>
      </button>
      <button class="demo-tab rounded-full border border-kobi-border px-4 py-2 text-sm font-semibold text-kobi-muted transition hover:border-kobi-muted hover:text-kobi-text" data-tab="freelance">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
          <span data-i18n="demo.tab.freelance">Freelance</span>
        </span>
      </button>
      <button class="demo-tab rounded-full border border-kobi-border px-4 py-2 text-sm font-semibold text-kobi-muted transition hover:border-kobi-muted hover:text-kobi-text" data-tab="code">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>
          <span data-i18n="demo.tab.code">Code</span>
        </span>
      </button>
    </div>

    <!-- Demo panels -->
    <div class="relative">

      <!-- ===== KOBI CHAT ===== -->
      <div class="demo-panel active" data-panel="chat">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <div class="fade-in">
            <div class="mb-2 inline-block rounded-full bg-emerald-500/20 px-3 py-1 text-xs font-semibold text-emerald-400">
              LIVE NOW
            </div>
            <h3 class="mb-4 text-2xl font-bold text-white md:text-3xl" data-i18n="demo.chat.title">
              AI chat assistant on the web
            </h3>
            <p class="mb-6 text-kobi-muted" data-i18n="demo.chat.desc">
              Ask anything in Bangla, Banglish, or English. Get instant AI answers from your browser. No app needed — just open chat.kobidev.com.
            </p>
            <ul class="mb-6 space-y-2">
              <li class="flex items-center gap-2 text-sm text-kobi-text">
                <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span data-i18n="demo.chat.f1">Works from any browser, any device</span>
              </li>
              <li class="flex items-center gap-2 text-sm text-kobi-text">
                <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span data-i18n="demo.chat.f2">Bangla, Banglish, and English</span>
              </li>
              <li class="flex items-center gap-2 text-sm text-kobi-text">
                <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span data-i18n="demo.chat.f3">Conversation history saved</span>
              </li>
              <li class="flex items-center gap-2 text-sm text-kobi-text">
                <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span data-i18n="demo.chat.f4">1 credit per message</span>
              </li>
            </ul>
            <div class="flex flex-col gap-3 sm:flex-row">
              <a href="https://chat.kobidev.com" target="_blank" rel="noopener noreferrer" class="rounded-lg bg-emerald-500 px-5 py-2.5 text-center text-sm font-semibold text-black transition hover:bg-emerald-400" data-i18n="demo.chat.cta1">
                Open Kobi Chat &rarr;
              </a>
              <a href="https://app.kobidev.com/signup" class="rounded-lg border border-kobi-border px-5 py-2.5 text-center text-sm font-semibold text-white transition hover:border-kobi-muted" data-i18n="demo.chat.cta2">
                Create free account
              </a>
            </div>
          </div>
          <!-- Chat browser mockup -->
          <div class="fade-in">
            <div class="mx-auto max-w-lg rounded-xl border border-kobi-border bg-kobi-surface overflow-hidden shadow-2xl">
              <div class="flex items-center gap-2 px-4 py-2.5 bg-[#111] border-b border-kobi-border">
                <div class="flex gap-1.5">
                  <span class="w-3 h-3 rounded-full bg-red-500/40"></span>
                  <span class="w-3 h-3 rounded-full bg-yellow-500/40"></span>
                  <span class="w-3 h-3 rounded-full bg-green-500/40"></span>
                </div>
                <span class="text-xs text-kobi-muted ml-2">chat.kobidev.com</span>
              </div>
              <div class="p-4 space-y-3">
                <!-- User message -->
                <div class="flex justify-end">
                  <div class="bg-emerald-600 text-white px-3 py-2 rounded-2xl rounded-br-md text-xs max-w-[80%]" data-i18n="demo.chat.q1">
                    ami ekta e-commerce site banate chai, kothay theke shuru korbo?
                  </div>
                </div>
                <!-- AI response -->
                <div class="flex justify-start">
                  <div class="bg-[#1a1a1a] border border-kobi-border px-3 py-2 rounded-2xl rounded-bl-md text-xs text-kobi-text max-w-[85%]" data-i18n="demo.chat.a1">
                    E-commerce site er jonno plan:
                  </div>
                </div>
                <div class="flex justify-start">
                  <div class="bg-[#1a1a1a] border border-kobi-border px-3 py-2 rounded-2xl rounded-bl-md text-xs text-kobi-text max-w-[85%]">
                    <div class="space-y-1 text-[11px]" data-i18n="demo.chat.a2">
                      <div>1. <strong class="text-emerald-400">Tech stack:</strong> React + Node.js + PostgreSQL</div>
                      <div>2. <strong class="text-emerald-400">Payment:</strong> bKash + Nagad integration</div>
                      <div>3. <strong class="text-emerald-400">Hosting:</strong> Vercel (free tier) + Supabase</div>
                      <div>4. <strong class="text-emerald-400">Delivery:</strong> Pathao/Steadfast API</div>
                    </div>
                  </div>
                </div>
                <!-- Follow-up -->
                <div class="flex justify-end">
                  <div class="bg-emerald-600 text-white px-3 py-2 rounded-2xl rounded-br-md text-xs max-w-[80%]" data-i18n="demo.chat.q2">
                    bKash integration er code daw
                  </div>
                </div>
                <!-- Typing indicator -->
                <div class="flex justify-start">
                  <div class="bg-[#1a1a1a] border border-kobi-border px-3 py-2 rounded-2xl rounded-bl-md text-xs text-kobi-muted">
                    <span class="inline-flex gap-1">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-bounce" style="animation-delay: 0ms"></span>
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-bounce" style="animation-delay: 150ms"></span>
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-bounce" style="animation-delay: 300ms"></span>
                    </span>
                  </div>
                </div>
              </div>
              <!-- Input bar -->
              <div class="px-4 py-3 border-t border-kobi-border bg-[#111] flex items-center gap-2">
                <div class="flex-1 bg-kobi-bg border border-kobi-border rounded-lg px-3 py-2 text-[11px] text-kobi-muted" data-i18n="demo.chat.placeholder">Type your message...</div>
                <div class="w-7 h-7 rounded-lg bg-emerald-500 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3.5 h-3.5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ===== KOBI SMS ===== -->
      <div class="demo-panel hidden" data-panel="sms">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <div class="fade-in">
            <div class="mb-2 inline-block rounded-full bg-kobi-border px-3 py-1 text-xs font-semibold text-kobi-muted">
              COMING SOON
            </div>
            <h3 class="mb-4 text-2xl font-bold text-white md:text-3xl" data-i18n="demo.sms.title">
              AI via SMS — no internet needed
            </h3>
            <p class="mb-6 text-kobi-muted" data-i18n="demo.sms.desc">
              Text a question to Kobi, get an AI answer back. Works on any phone — even basic feature phones. Bangla and Banglish supported.
            </p>
            <ul class="mb-6 space-y-2">
              <li class="flex items-center gap-2 text-sm text-kobi-text">
                <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span data-i18n="demo.sms.f1">Works without internet</span>
              </li>
              <li class="flex items-center gap-2 text-sm text-kobi-text">
                <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span data-i18n="demo.sms.f2">Any phone — smartphone or feature phone</span>
              </li>
              <li class="flex items-center gap-2 text-sm text-kobi-text">
                <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span data-i18n="demo.sms.f3">Bangla, Banglish, and English</span>
              </li>
              <li class="flex items-center gap-2 text-sm text-kobi-text">
                <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span data-i18n="demo.sms.f4">2 credits per SMS query</span>
              </li>
            </ul>
          </div>
          <!-- SMS phone mockup with carousel -->
          <div class="fade-in flex justify-center">
            <div class="w-72 rounded-[2rem] border-2 border-kobi-border bg-[#111] p-3 shadow-2xl">
              <!-- Phone notch -->
              <div class="mx-auto mb-3 h-5 w-24 rounded-full bg-kobi-border/50"></div>
              <!-- Phone screen -->
              <div class="rounded-2xl bg-kobi-bg overflow-hidden">
                <!-- SMS header -->
                <div class="bg-[#1a1a1a] px-4 py-3 text-center border-b border-kobi-border">
                  <div class="text-xs text-kobi-muted">SMS</div>
                  <div class="text-sm font-semibold text-white">Kobi AI</div>
                  <div class="text-[10px] text-kobi-muted">16XXX</div>
                </div>
                <!-- Carousel container -->
                <div class="sms-carousel relative overflow-hidden">
                  <div class="sms-carousel-track flex transition-transform duration-500 ease-in-out">
                    <!-- Slide 1: English Fix -->
                    <div class="sms-slide w-full flex-shrink-0 p-3 space-y-2.5 min-h-[280px]">
                      <div class="text-center mb-2">
                        <span class="text-[9px] font-semibold uppercase tracking-wider text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full" data-i18n="demo.sms.label1">English Fix</span>
                      </div>
                      <div class="flex justify-end">
                        <div class="bg-emerald-600 text-white px-3 py-2 rounded-2xl rounded-br-md text-xs max-w-[80%]" data-i18n="demo.sms.q1">eng thik koro: i am go market tommorow for buy phone</div>
                      </div>
                      <div class="flex justify-start">
                        <div class="bg-[#1a1a1a] border border-kobi-border px-3 py-2 rounded-2xl rounded-bl-md text-xs text-kobi-text max-w-[85%]" data-i18n="demo.sms.a1">"I am going to the market tomorrow to buy a phone." ✅ (tip: go → going to, for buy → to buy, tommorow → tomorrow)</div>
                      </div>
                    </div>
                    <!-- Slide 2: Life Advice -->
                    <div class="sms-slide w-full flex-shrink-0 p-3 space-y-2.5 min-h-[280px]">
                      <div class="text-center mb-2">
                        <span class="text-[9px] font-semibold uppercase tracking-wider text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full" data-i18n="demo.sms.label2">Life Advice</span>
                      </div>
                      <div class="flex justify-end">
                        <div class="bg-emerald-600 text-white px-3 py-2 rounded-2xl rounded-br-md text-xs max-w-[80%]" data-i18n="demo.sms.q2">gf er birthday, 500tk budget, ki korbo bro? 😅</div>
                      </div>
                      <div class="flex justify-start">
                        <div class="bg-[#1a1a1a] border border-kobi-border px-3 py-2 rounded-2xl rounded-bl-md text-xs text-kobi-text max-w-[85%]" data-i18n="demo.sms.a2">Top plan 500tk te: 1) Handmade card + chocolate (150tk) 2) Photo collage print (100tk) 3) Rooftop e fairy light date (250tk) 🎉 Budget e beshi value!</div>
                      </div>
                    </div>
                    <!-- Slide 3: CV Help -->
                    <div class="sms-slide w-full flex-shrink-0 p-3 space-y-2.5 min-h-[280px]">
                      <div class="text-center mb-2">
                        <span class="text-[9px] font-semibold uppercase tracking-wider text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full" data-i18n="demo.sms.label3">CV Help</span>
                      </div>
                      <div class="flex justify-end">
                        <div class="bg-emerald-600 text-white px-3 py-2 rounded-2xl rounded-br-md text-xs max-w-[80%]" data-i18n="demo.sms.q3">amr CV te ki ki likhbo? garments e 3 bochor kaj korsi</div>
                      </div>
                      <div class="flex justify-start">
                        <div class="bg-[#1a1a1a] border border-kobi-border px-3 py-2 rounded-2xl rounded-bl-md text-xs text-kobi-text max-w-[85%]" data-i18n="demo.sms.a3">CV te likhen: 1) Production line supervisor, 2) Quality control experience, 3) Team management 50+ workers. Arekta section e skills: sewing machine operation, compliance, deadline management.</div>
                      </div>
                    </div>
                    <!-- Slide 4: Interview Prep -->
                    <div class="sms-slide w-full flex-shrink-0 p-3 space-y-2.5 min-h-[280px]">
                      <div class="text-center mb-2">
                        <span class="text-[9px] font-semibold uppercase tracking-wider text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full" data-i18n="demo.sms.label4">Interview Prep</span>
                      </div>
                      <div class="flex justify-end">
                        <div class="bg-emerald-600 text-white px-3 py-2 rounded-2xl rounded-br-md text-xs max-w-[80%]" data-i18n="demo.sms.q4">interview e "tell me about yourself" er answer ki hobe?</div>
                      </div>
                      <div class="flex justify-start">
                        <div class="bg-[#1a1a1a] border border-kobi-border px-3 py-2 rounded-2xl rounded-bl-md text-xs text-kobi-text max-w-[85%]" data-i18n="demo.sms.a4">Template: "I have [X] years experience in [field]. Currently I [current role]. My key strength is [skill]. I'm looking for [goal]." Practice kore niben, 30 sec er moddhe shesh korun!</div>
                      </div>
                    </div>
                    <!-- Slide 5: Upwork Proposal -->
                    <div class="sms-slide w-full flex-shrink-0 p-3 space-y-2.5 min-h-[280px]">
                      <div class="text-center mb-2">
                        <span class="text-[9px] font-semibold uppercase tracking-wider text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full" data-i18n="demo.sms.label5">Upwork Proposal</span>
                      </div>
                      <div class="flex justify-end">
                        <div class="bg-emerald-600 text-white px-3 py-2 rounded-2xl rounded-br-md text-xs max-w-[80%]" data-i18n="demo.sms.q5">upwork e react job er jonno proposal likh</div>
                      </div>
                      <div class="flex justify-start">
                        <div class="bg-[#1a1a1a] border border-kobi-border px-3 py-2 rounded-2xl rounded-bl-md text-xs text-kobi-text max-w-[85%]" data-i18n="demo.sms.a5">"Hi! I specialize in React with 2+ yrs building SPAs & dashboards. I noticed you need [specific detail from job post]. I've built similar projects including bKash payment UIs. Available to start immediately."</div>
                      </div>
                    </div>
                    <!-- Slide 6: Farming -->
                    <div class="sms-slide w-full flex-shrink-0 p-3 space-y-2.5 min-h-[280px]">
                      <div class="text-center mb-2">
                        <span class="text-[9px] font-semibold uppercase tracking-wider text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full" data-i18n="demo.sms.label6">Farming</span>
                      </div>
                      <div class="flex justify-end">
                        <div class="bg-emerald-600 text-white px-3 py-2 rounded-2xl rounded-br-md text-xs max-w-[80%]" data-i18n="demo.sms.q6">dhan e poka lagse, ki spray korbo?</div>
                      </div>
                      <div class="flex justify-start">
                        <div class="bg-[#1a1a1a] border border-kobi-border px-3 py-2 rounded-2xl rounded-bl-md text-xs text-kobi-text max-w-[85%]" data-i18n="demo.sms.a6">Dhan er stem borer hole: Cartap hydrochloride 4G spray korun (bigha te 3kg). Bikal e spray korun, 10 din por abar. Sesh kore hat-muk dhue felen. Jodi beshi hole, upazila krishi officer er kase jan.</div>
                      </div>
                    </div>
                    <!-- Slide 7: Health -->
                    <div class="sms-slide w-full flex-shrink-0 p-3 space-y-2.5 min-h-[280px]">
                      <div class="text-center mb-2">
                        <span class="text-[9px] font-semibold uppercase tracking-wider text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full" data-i18n="demo.sms.label7">Health</span>
                      </div>
                      <div class="flex justify-end">
