---
---

<section id="templates" class="py-20 md:py-28 border-b border-kobi-border">
  <div class="mx-auto max-w-6xl px-4">
    <div class="fade-in grid gap-12 md:grid-cols-2 items-center">
      <!-- Left: text -->
      <div>
        <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="templates.title">
          Built-in templates for Bangladesh
        </h2>
        <p class="text-lg text-kobi-muted mb-6" data-i18n="templates.subtitle">
          Pre-built code templates for bKash, Nagad, NID verification, and more. Just click and start coding.
        </p>
        <div class="grid grid-cols-2 gap-3">
          <div class="flex items-center gap-2 rounded-lg border border-kobi-border bg-kobi-surface px-3 py-2.5">
            <span>💳</span>
            <span class="text-sm text-kobi-text" data-i18n="templates.bkash">bKash Payment</span>
          </div>
          <div class="flex items-center gap-2 rounded-lg border border-kobi-border bg-kobi-surface px-3 py-2.5">
            <span>💳</span>
            <span class="text-sm text-kobi-text" data-i18n="templates.nagad">Nagad Payment</span>
          </div>
          <div class="flex items-center gap-2 rounded-lg border border-kobi-border bg-kobi-surface px-3 py-2.5">
            <span>🪪</span>
            <span class="text-sm text-kobi-text" data-i18n="templates.nid">NID Verification</span>
          </div>
          <div class="flex items-center gap-2 rounded-lg border border-kobi-border bg-kobi-surface px-3 py-2.5">
            <span>🛒</span>
            <span class="text-sm text-kobi-text" data-i18n="templates.ecom">E-commerce (BDT)</span>
          </div>
          <div class="flex items-center gap-2 rounded-lg border border-kobi-border bg-kobi-surface px-3 py-2.5">
            <span>🚚</span>
            <span class="text-sm text-kobi-text" data-i18n="templates.pathao">Pathao Delivery</span>
          </div>
          <div class="flex items-center gap-2 rounded-lg border border-kobi-border bg-kobi-surface px-3 py-2.5">
            <span>📱</span>
            <span class="text-sm text-kobi-text" data-i18n="templates.sms">SMS Gateway</span>
          </div>
        </div>
        <p class="mt-4 text-sm text-kobi-muted" data-i18n="templates.available">
          Available on Starter plan and above
        </p>
      </div>

      <!-- Right: animated bKash code demo -->
      <div class="rounded-xl border border-kobi-border bg-kobi-surface overflow-hidden shadow-2xl">
        <div class="flex items-center gap-2 px-4 py-2.5 bg-[#111] border-b border-kobi-border">
          <div class="flex gap-1.5">
            <span class="w-3 h-3 rounded-full bg-red-500/40"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/40"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/40"></span>
          </div>
          <span class="text-xs text-kobi-muted ml-2">BkashController.php — Kobi AI</span>
        </div>
        <div class="p-4 font-mono text-sm leading-relaxed">
          <div class="text-kobi-muted">
            <span class="text-violet-400">class</span> <span class="text-emerald-400">BkashController</span>
          </div>
          <div class="text-kobi-muted">{</div>
          <div class="pl-4">
            <span class="text-violet-400">public function</span> <span class="text-amber-400">createPayment</span>(<span class="text-kobi-muted">$request</span>)
          </div>
          <div class="pl-4 text-kobi-muted">{</div>
          <div class="pl-8 text-kobi-muted/50 bkash-line-1 opacity-0" style="animation: fadeSlideIn 0.4s ease forwards 0.5s;">
            <span class="text-kobi-muted/70">$amount</span> = <span class="text-kobi-muted/70">$request</span>-><span class="text-amber-400/60">amount</span>;
          </div>
          <div class="pl-8 text-kobi-muted/50 bkash-line-2 opacity-0" style="animation: fadeSlideIn 0.4s ease forwards 1s;">
            <span class="text-kobi-muted/70">$invoice</span> = <span class="text-emerald-400/60">Str</span>::<span class="text-amber-400/60">uuid</span>();
          </div>
          <div class="pl-8 text-kobi-muted/50 bkash-line-3 opacity-0" style="animation: fadeSlideIn 0.4s ease forwards 1.5s;">
            <span class="text-violet-400/60">return</span> <span class="text-emerald-400/60">Bkash</span>::<span class="text-amber-400/60">createPayment</span>([
          </div>
          <div class="pl-12 text-kobi-muted/50 bkash-line-4 opacity-0" style="animation: fadeSlideIn 0.4s ease forwards 2s;">
            <span class="text-amber-400/60">'amount'</span> => <span class="text-kobi-muted/70">$amount</span>,
          </div>
          <div class="pl-12 text-kobi-muted/50 bkash-line-5 opacity-0" style="animation: fadeSlideIn 0.4s ease forwards 2.5s;">
            <span class="text-amber-400/60">'invoice'</span> => <span class="text-kobi-muted/70">$invoice</span>,
          </div>
          <div class="pl-8 text-kobi-muted/50 bkash-line-6 opacity-0" style="animation: fadeSlideIn 0.4s ease forwards 3s;">
            ]);
          </div>
          <div class="pl-4 text-kobi-muted">}</div>
          <div class="text-kobi-muted">}</div>
        </div>
        <div class="px-4 py-2 border-t border-kobi-border bg-[#111]">
          <span class="text-xs text-emerald-400">Kobi</span>
          <span class="text-xs text-kobi-muted ml-1" data-i18n="templates.suggesting">generated bKash integration from template</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
