---
const steps = [
  {
    number: "1",
    title: "Install the extension",
    description:
      "Download and install the Kobi extension in VS Code. Takes less than a minute.",
    icon: `<svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>`,
  },
  {
    number: "2",
    title: "Sign up & pay with bKash",
    description:
      "Create your account and choose a plan. Send payment via bKash — activated within 2 hours.",
    icon: `<svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg>`,
  },
  {
    number: "3",
    title: "Start coding with AI",
    description:
      "Get inline completions, chat with AI about your code, and let the agent handle complex tasks.",
    icon: `<svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>`,
  },
];
---

<section id="download" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="fade-in mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">
        Get started in 3 steps
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted">
        From install to AI-powered coding in under 5 minutes.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {
        steps.map((step) => (
          <div class="fade-in text-center">
            <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-2xl border border-kobi-border bg-kobi-surface text-emerald-500">
              <Fragment set:html={step.icon} />
            </div>
            <div class="mb-2 text-sm font-semibold text-emerald-500">
              Step {step.number}
            </div>
            <h3 class="mb-2 text-xl font-semibold text-white">{step.title}</h3>
            <p class="leading-relaxed text-kobi-muted">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
