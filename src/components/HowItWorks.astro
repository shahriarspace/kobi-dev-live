---
const steps = [
  {
    number: "1",
    titleKey: "how.1.title",
    title: "Create your account",
    descKey: "how.1.desc",
    desc: "Sign up free at app.kobidev.com. No card needed. Get 50 bonus credits instantly.",
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>`,
  },
  {
    number: "2",
    titleKey: "how.2.title",
    title: "Buy credits with bKash",
    descKey: "how.2.desc",
    desc: "Choose a monthly plan or top-up pack. Send payment via bKash or Nagad — activated within 30 minutes.",
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg>`,
  },
  {
    number: "3",
    titleKey: "how.3.title",
    title: "Use any Kobi app",
    descKey: "how.3.desc",
    desc: "Install the VS Code extension, open web chat, or text via SMS. Your credits work across all Kobi apps.",
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/></svg>`,
  },
];
---

<section id="download" class="py-20 md:py-28 border-b border-kobi-border">
  <div class="mx-auto max-w-4xl px-4">
    <div class="fade-in mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="how.title">
        Get started in 3 steps
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="how.subtitle">
        From sign-up to AI-powered productivity in under 5 minutes.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {steps.map((step) => (
        <div class="fade-in text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-emerald-500/10 text-emerald-400">
            <Fragment set:html={step.icon} />
          </div>
          <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-emerald-400">
            <span data-i18n="how.step">Step</span> {step.number}
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white" data-i18n={step.titleKey}>
            {step.title}
          </h3>
          <p class="text-sm leading-relaxed text-kobi-muted" data-i18n={step.descKey}>
            {step.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
