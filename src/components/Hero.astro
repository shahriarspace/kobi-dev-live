---
---

<section class="relative overflow-hidden pt-32 pb-20 md:pt-40 md:pb-32">
  <!-- Gradient background -->
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-emerald-500/5 via-transparent to-transparent"
  >
  </div>

  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Left: Copy -->
      <div class="fade-in">
        <div
          class="mb-4 inline-block rounded-full border border-emerald-500/30 bg-emerald-500/10 px-4 py-1.5 text-sm text-emerald-400"
          data-i18n="hero.badge"
        >
          AI for everyone
        </div>
        <h1
          class="mb-6 text-5xl font-black leading-tight tracking-tight text-white md:text-6xl lg:text-7xl"
        >
          <span data-i18n="hero.title.1">The AI platform</span><br /><span data-i18n="hero.title.2">of </span><span class="text-emerald-500" data-i18n="hero.title.accent">Bangladesh</span>
        </h1>
        <p class="mb-8 max-w-lg text-lg leading-relaxed text-kobi-muted md:text-xl" data-i18n="hero.description">
          Code, communicate, prepare, build — all with AI. Pay in BDT via bKash.
          No international card needed. One credit wallet for everything.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a
            href="https://app.kobidev.com/signup"
            class="rounded-lg bg-emerald-500 px-8 py-3 text-center font-semibold text-black transition hover:bg-emerald-400"
            data-i18n="hero.cta.primary"
          >
            Start free &rarr;
          </a>
          <a
            href="#pricing"
            class="rounded-lg border border-kobi-border px-8 py-3 text-center font-semibold text-white transition hover:border-kobi-muted hover:bg-kobi-surface"
            data-i18n="hero.cta.secondary"
          >
            See pricing
          </a>
        </div>
        <div
          class="mt-8 flex flex-wrap gap-6 text-sm text-kobi-muted"
        >
          <span class="flex items-center gap-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            <span data-i18n="hero.stat.1">185M Bangladeshis</span>
          </span>
          <span class="flex items-center gap-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            <span data-i18n="hero.stat.2">1 Credit = ৳1</span>
          </span>
          <span class="flex items-center gap-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            <span data-i18n="hero.stat.3">bKash / Nagad</span>
          </span>
          <span class="flex items-center gap-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            <span data-i18n="hero.stat.4">Powered by Claude</span>
          </span>
        </div>
      </div>

      <!-- Right: Product bento grid -->
      <div class="fade-in">
        <div class="grid grid-cols-2 gap-3">

          <!-- Kobi Chat — large card spanning 2 cols -->
          <a href="https://chat.kobidev.com" target="_blank" rel="noopener noreferrer" class="group col-span-2 rounded-xl border border-emerald-500/30 bg-emerald-500/5 p-4 transition hover:border-emerald-500/50 hover:bg-emerald-500/10">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-500/20 text-emerald-400">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-white">Kobi Chat</div>
                <div class="text-[10px] text-emerald-400 font-semibold">LIVE</div>
              </div>
            </div>
            <!-- Mini chat preview -->
            <div class="space-y-1.5">
              <div class="flex justify-end">
                <div class="bg-emerald-600/80 text-white px-2 py-1 rounded-xl rounded-br-sm text-[10px] max-w-[85%]" data-i18n="hero.chat.q">bKash API integrate korbo kivabe?</div>
              </div>
              <div class="flex justify-start">
                <div class="bg-[#1a1a1a] border border-kobi-border px-2 py-1 rounded-xl rounded-bl-sm text-[10px] text-kobi-text max-w-[85%]" data-i18n="hero.chat.a">bKash Tokenized API use korun. Step 1: Grant token...</div>
              </div>
            </div>
          </a>

          <!-- Kobi SMS -->
          <a href="#spotlight" class="group rounded-xl border border-kobi-border bg-kobi-surface p-4 transition hover:border-kobi-muted hover:bg-kobi-surface/80">
            <div class="flex items-center gap-2.5 mb-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-kobi-border/50 text-kobi-muted">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-6 18h6"/></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-white">Kobi SMS</div>
                <div class="text-[10px] text-kobi-muted" data-i18n="hero.soon">Coming Soon</div>
              </div>
            </div>
            <!-- SMS preview -->
            <div class="space-y-1.5">
              <div class="flex justify-end">
                <div class="bg-emerald-600/80 text-white px-2 py-1 rounded-xl rounded-br-sm text-[10px] max-w-[85%]" data-i18n="hero.sms.q">eng thik koro: i am go market</div>
              </div>
              <div class="flex justify-start">
                <div class="bg-[#1a1a1a] border border-kobi-border px-2 py-1 rounded-xl rounded-bl-sm text-[10px] text-kobi-text max-w-[85%]" data-i18n="hero.sms.a">"I am going to the market" ✅</div>
              </div>
            </div>
          </a>

          <!-- Kobi CV -->
          <a href="#spotlight" class="group rounded-xl border border-kobi-border bg-kobi-surface p-4 transition hover:border-kobi-muted hover:bg-kobi-surface/80">
            <div class="flex items-center gap-2.5 mb-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-kobi-border/50 text-kobi-muted">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-white">Kobi CV</div>
                <div class="text-[10px] text-kobi-muted" data-i18n="hero.soon">Coming Soon</div>
              </div>
            </div>
            <!-- CV preview -->
            <div class="rounded-lg bg-white p-2">
              <div class="h-2 w-16 rounded bg-emerald-500 mb-1.5"></div>
              <div class="h-1.5 w-24 rounded bg-gray-300 mb-1"></div>
              <div class="space-y-0.5">
                <div class="h-1 w-full rounded bg-gray-200"></div>
                <div class="h-1 w-4/5 rounded bg-gray-200"></div>
                <div class="h-1 w-3/5 rounded bg-gray-200"></div>
              </div>
            </div>
          </a>

          <!-- Kobi Interview -->
          <a href="#spotlight" class="group rounded-xl border border-kobi-border bg-kobi-surface p-4 transition hover:border-kobi-muted hover:bg-kobi-surface/80">
            <div class="flex items-center gap-2.5 mb-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-kobi-border/50 text-kobi-muted">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-white">Kobi Interview</div>
                <div class="text-[10px] text-kobi-muted" data-i18n="hero.soon">Coming Soon</div>
              </div>
            </div>
            <!-- Interview preview -->
            <div class="space-y-1.5">
              <div class="bg-[#1a1a1a] border border-kobi-border px-2 py-1 rounded-lg text-[10px] text-kobi-text" data-i18n="hero.interview.q">What is useEffect?</div>
              <div class="flex items-center gap-1">
                <span class="text-yellow-400 text-[10px]">&#9733;&#9733;&#9733;&#9733;</span><span class="text-kobi-muted text-[10px]">&#9733;</span>
                <span class="text-[9px] text-kobi-muted">4/5</span>
              </div>
            </div>
          </a>

          <!-- Kobi Freelance -->
          <a href="#spotlight" class="group rounded-xl border border-kobi-border bg-kobi-surface p-4 transition hover:border-kobi-muted hover:bg-kobi-surface/80">
            <div class="flex items-center gap-2.5 mb-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-kobi-border/50 text-kobi-muted">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-white">Kobi Freelance</div>
                <div class="text-[10px] text-kobi-muted" data-i18n="hero.soon">Coming Soon</div>
              </div>
            </div>
            <!-- Proposal preview -->
            <div class="rounded-lg bg-[#1a1a1a] border border-kobi-border p-2 text-[10px]">
              <div class="text-emerald-400 font-semibold mb-0.5" data-i18n="hero.freelance.label">AI Proposal</div>
              <div class="space-y-0.5">
                <div class="h-1 w-full rounded bg-kobi-border"></div>
                <div class="h-1 w-4/5 rounded bg-kobi-border"></div>
                <div class="h-1 w-3/5 rounded bg-kobi-border"></div>
              </div>
            </div>
          </a>

          <!-- Kobi Code -->
          <a href="#spotlight" class="group rounded-xl border border-emerald-500/30 bg-emerald-500/5 p-4 transition hover:border-emerald-500/50 hover:bg-emerald-500/10">
            <div class="flex items-center gap-2.5 mb-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-500/20 text-emerald-400">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-white">Kobi Code</div>
                <div class="text-[10px] text-emerald-400 font-semibold">LIVE</div>
              </div>
            </div>
            <!-- Mini code preview -->
            <div class="rounded-lg bg-[#111] border border-kobi-border p-3 font-mono text-[11px] leading-relaxed">
              <div><span class="text-kobi-muted/50 mr-2">1</span><span class="text-white">function</span> <span class="text-emerald-400">fibonacci</span><span class="text-white">(n) {</span></div>
              <div><span class="text-kobi-muted/50 mr-2">2</span><span class="text-emerald-400/70">  if (n &lt;= 1) return n;</span></div>
              <div class="flex items-center gap-1 mt-1 text-[9px] text-kobi-muted">
                <svg class="h-2.5 w-2.5 animate-spin" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                <span data-i18n="code.suggesting">Kobi is suggesting...</span>
              </div>
            </div>
          </a>

        </div>
      </div>
    </div>
  </div>
</section>
