---
---

<section id="starter" class="py-20 md:py-28" style="background: linear-gradient(180deg, #064e3b 0%, #0a0a0a 100%);">
  <div class="mx-auto max-w-6xl px-4">
    <div class="fade-in grid gap-12 md:grid-cols-2 items-center">
      <!-- Left: value prop -->
      <div>
        <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="starter.title">
          Start for less than a cup of tea
        </h2>
        <p class="text-xl text-emerald-300 mb-6" data-i18n="starter.price">
          ৳150/month. That's ৳5 per day.
        </p>

        <!-- ROI calculation -->
        <div class="rounded-xl border border-emerald-700/30 bg-emerald-900/20 p-5 mb-6">
          <p class="text-sm text-emerald-200 mb-2" data-i18n="starter.roi.title">If Kobi saves you just 30 minutes/day at ৳500/hr freelance rate:</p>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <div class="text-2xl font-bold text-emerald-400">৳150</div>
              <div class="text-xs text-emerald-300/60" data-i18n="starter.roi.cost">Cost</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-emerald-400">৳7,500</div>
              <div class="text-xs text-emerald-300/60" data-i18n="starter.roi.saved">Saved</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-emerald-400">50x</div>
              <div class="text-xs text-emerald-300/60">ROI</div>
            </div>
          </div>
        </div>

        <!-- What you unlock -->
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-emerald-400 uppercase tracking-wide mb-3" data-i18n="starter.unlock">What you unlock</h3>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-white">
              <svg class="h-4 w-4 flex-shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span data-i18n="starter.f1">100 AI chat messages/month</span>
            </li>
            <li class="flex items-center gap-2 text-sm text-white">
              <svg class="h-4 w-4 flex-shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span data-i18n="starter.f2">500 inline completions</span>
            </li>
            <li class="flex items-center gap-2 text-sm text-white">
              <svg class="h-4 w-4 flex-shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span data-i18n="starter.f3">Web chat — use from any browser</span>
            </li>
            <li class="flex items-center gap-2 text-sm text-white">
              <svg class="h-4 w-4 flex-shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span data-i18n="starter.f4">BD templates: bKash, Nagad, NID + 5 more</span>
            </li>
            <li class="flex items-center gap-2 text-sm text-white">
              <svg class="h-4 w-4 flex-shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span data-i18n="starter.f5">Chat history saved forever</span>
            </li>
            <li class="flex items-center gap-2 text-sm text-white">
              <svg class="h-4 w-4 flex-shrink-0 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span data-i18n="starter.f6">Pay with bKash in 60 seconds</span>
            </li>
          </ul>
        </div>

        <!-- vs Free plan -->
        <div>
          <h3 class="text-sm font-semibold text-kobi-muted uppercase tracking-wide mb-3" data-i18n="starter.free">vs Free plan</h3>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-kobi-muted">
              <svg class="h-4 w-4 flex-shrink-0 text-red-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              <span data-i18n="starter.nf1">No web chat</span>
            </li>
            <li class="flex items-center gap-2 text-sm text-kobi-muted">
              <svg class="h-4 w-4 flex-shrink-0 text-red-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              <span data-i18n="starter.nf2">No BD templates</span>
            </li>
            <li class="flex items-center gap-2 text-sm text-kobi-muted">
              <svg class="h-4 w-4 flex-shrink-0 text-red-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              <span data-i18n="starter.nf3">No chat history</span>
            </li>
            <li class="flex items-center gap-2 text-sm text-kobi-muted">
              <svg class="h-4 w-4 flex-shrink-0 text-red-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              <span data-i18n="starter.nf4">Only 20 chats/month (3 days of normal use)</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Right: CTA card -->
      <div class="rounded-2xl border border-emerald-500/30 bg-emerald-900/10 p-8 shadow-2xl shadow-emerald-500/10 backdrop-blur-sm">
        <h3 class="text-2xl font-bold text-white mb-2" data-i18n="starter.card.name">Starter Plan</h3>

        <!-- Launch offer price -->
        <div class="mb-4">
          <span class="text-kobi-muted line-through text-lg">৳150</span>
          <span class="text-4xl font-bold text-emerald-400 ml-2">৳99</span>
          <span class="text-kobi-muted ml-1" data-i18n="starter.card.first">first month</span>
        </div>
        <div class="inline-block rounded-full bg-emerald-500/20 px-3 py-1 text-xs font-semibold text-emerald-400 mb-4" data-i18n="starter.card.offer">
          Launch offer
        </div>
        <p class="text-sm text-kobi-muted mb-6" data-i18n="starter.card.then">then ৳150/month</p>

        <!-- CTA -->
        <a
          href="https://app.kobidev.com/signup?plan=starter"
          class="block w-full rounded-lg bg-emerald-500 py-3.5 text-center text-base font-semibold text-black transition hover:bg-emerald-400 mb-6"
          data-i18n="starter.card.cta"
        >
          Start for ৳99 →
        </a>

        <!-- Reassurance -->
        <ul class="space-y-2.5">
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="starter.card.r1">Activates within 30 minutes</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="starter.card.r2">Pay with bKash</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="starter.card.r3">No card needed</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-kobi-muted">
            <svg class="h-4 w-4 flex-shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span data-i18n="starter.card.r4">Cancel anytime</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
