---
const features = [
  {
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`,
    titleKey: "features.1.title",
    descKey: "features.1.desc",
    title: "Inline completions",
    description: "Ghost text suggestions as you type — just like GitHub Copilot. Tab to accept, keep coding.",
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
    titleKey: "features.2.title",
    descKey: "features.2.desc",
    title: "AI chat panel",
    description: "Ask questions about your code, get explanations, debug errors — right inside VS Code.",
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/></svg>`,
    titleKey: "features.3.title",
    descKey: "features.3.desc",
    title: "Agent mode",
    description: "Let AI handle multi-file tasks autonomously — refactoring, test writing, feature implementation.",
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>`,
    titleKey: "features.4.title",
    descKey: "features.4.desc",
    title: "Pay in BDT",
    description: "bKash, Nagad — no international card needed. Plans from ৳500/month. Built for Bangladesh.",
  },
];
---

<section id="features" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="fade-in mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="features.title">
        Everything you need to code with AI
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="features.subtitle">
        Powered by Anthropic Claude — the same AI behind the best coding tools in the world.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {
        features.map((feature) => (
          <div class="fade-in group rounded-xl border border-kobi-border bg-kobi-surface p-8 transition hover:border-emerald-500/30">
            <div class="mb-4 text-emerald-500" set:html={feature.icon} />
            <h3 class="mb-2 text-xl font-semibold text-white" data-i18n={feature.titleKey}>
              {feature.title}
            </h3>
            <p class="leading-relaxed text-kobi-muted" data-i18n={feature.descKey}>{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
