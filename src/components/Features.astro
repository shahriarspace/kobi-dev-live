---
const features = [
  {
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>`,
    titleKey: "features.1.title",
    title: "Unified credits",
    descKey: "features.1.desc",
    desc: "1 Kobi Credit = ৳1 BDT. Buy once, use across all 5 apps. No separate subscriptions.",
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>`,
    titleKey: "features.2.title",
    title: "Bangla & Banglish",
    descKey: "features.2.desc",
    desc: "Full Bangla interface. AI understands Banglish input. Built by Bangladeshis, for Bangladeshis.",
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg>`,
    titleKey: "features.3.title",
    title: "bKash & Nagad",
    descKey: "features.3.desc",
    desc: "Pay with bKash or Nagad — no international card needed. Top up credits in 60 seconds.",
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`,
    titleKey: "features.4.title",
    title: "BD templates",
    descKey: "features.4.desc",
    desc: "Pre-built code for bKash, Nagad, NID verification, Pathao integration. One click — ready to use.",
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-6 18h6"/></svg>`,
    titleKey: "features.5.title",
    title: "Works everywhere",
    descKey: "features.5.desc",
    desc: "VS Code extension, web chat, SMS, mobile browser. Use Kobi from any device, even without internet via SMS.",
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    titleKey: "features.6.title",
    title: "Powered by Claude",
    descKey: "features.6.desc",
    desc: "Same AI behind the best coding tools in the world. Claude Haiku for speed, Sonnet for power.",
  },
];
---

<section id="features" class="py-20 md:py-28 border-b border-kobi-border">
  <div class="mx-auto max-w-6xl px-4">
    <div class="fade-in mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl" data-i18n="features.title">
        Built for Bangladesh, powered by world-class AI
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-kobi-muted" data-i18n="features.subtitle">
        Anthropic Claude powers everything. Pay in BDT. Get Bangla support. Use across all Kobi apps.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div class="fade-in rounded-xl border border-kobi-border bg-kobi-surface p-6">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white" data-i18n={feature.titleKey}>
            {feature.title}
          </h3>
          <p class="text-sm leading-relaxed text-kobi-muted" data-i18n={feature.descKey}>
            {feature.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
