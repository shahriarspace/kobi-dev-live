---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import "../../styles/global.css";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Kobi Blog — AI Tips, Tutorials & Updates for Bangladesh"
  description="Kobi Blog: AI tips, tutorials, guides. Freelancing, coding, CV making, interview prep — shob kichu shikho AI diye. Bangla o English e."
  keywords="AI blog Bangladesh, AI tips bangla, AI tutorial Bangladesh, freelancing tips, coding tips Bangladesh, AI news Bangladesh, tech blog Bangladesh, এআই ব্লগ, টেক ব্লগ বাংলাদেশ"
  path="/blog"
>
  <Navbar />
  <main>
    <section class="pt-32 pb-20 md:pt-40">
      <div class="mx-auto max-w-4xl px-4">
        <div class="mb-12 text-center">
          <div class="mb-4 inline-block rounded-full border border-emerald-500/30 bg-emerald-500/10 px-4 py-1.5 text-sm text-emerald-400">
            Blog
          </div>
          <h1 class="mb-4 text-4xl font-black text-white md:text-5xl">
            AI tips & insights
          </h1>
          <p class="mx-auto max-w-2xl text-lg text-kobi-muted">
            Freelancing, coding, career growth — AI kiveabe help korte pare shob kichu jano. Bangla o English e.
          </p>
        </div>

        {posts.length === 0 && (
          <p class="text-center text-kobi-muted">Coming soon — stay tuned!</p>
        )}

        <div class="grid gap-6 md:grid-cols-2">
          {posts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group rounded-xl border border-kobi-border bg-kobi-surface p-6 transition hover:border-emerald-500/50"
            >
              <div class="mb-3 flex flex-wrap gap-2">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="rounded-full border border-emerald-500/20 bg-emerald-500/5 px-2 py-0.5 text-xs text-emerald-400">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="mb-2 text-xl font-bold text-white group-hover:text-emerald-400 transition">
                {post.data.title}
              </h2>
              <p class="mb-3 text-sm text-kobi-muted line-clamp-2">
                {post.data.description}
              </p>
              <time
                datetime={post.data.date.toISOString()}
                class="text-xs text-kobi-muted"
              >
                {post.data.date.toLocaleDateString("en-GB", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
