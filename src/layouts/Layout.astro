---
import { translations } from "../i18n";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "বাংলাদেশি পেশাদারদের জন্য AI প্ল্যাটফর্ম। কোড, SMS, CV, ইন্টারভিউ, ফ্রিল্যান্স — সবকিছুতে AI। Anthropic Claude দিয়ে চলে। বিকাশে টাকায় পে করুন। মাত্র ৳১৫০/মাস থেকে।",
} = Astro.props;
---

<!doctype html>
<html lang="bn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="AI platform, Bangladesh, BDT, bKash, কোডিং, AI, বাংলাদেশ, VS Code, SMS AI, CV builder, interview coach, freelance proposal, কবি"
    />
    <meta name="author" content="Kobi" />
    <meta name="google-site-verification" content="xwZVlGH--ahwzCkJKSRHERvuIPYEYT8Yzka5oPPgbJw" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://kobidev.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://kobidev.com/og-image.png" />
    <meta property="og:locale" content="bn_BD" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Kobi",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Windows, macOS, Linux, Web, SMS",
        "description": "AI platform for Bangladeshi professionals. Code, SMS, CV, Interview, Freelance tools. Pay in BDT via bKash.",
        "offers": [
          {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "BDT",
            "name": "Free",
            "description": "50 one-time credits"
          },
          {
            "@type": "Offer",
            "price": "150",
            "priceCurrency": "BDT",
            "name": "Starter",
            "description": "200 credits/month"
          },
          {
            "@type": "Offer",
            "price": "400",
            "priceCurrency": "BDT",
            "name": "Basic",
            "description": "600 credits/month"
          },
          {
            "@type": "Offer",
            "price": "900",
            "priceCurrency": "BDT",
            "name": "Pro",
            "description": "1500 credits/month"
          },
          {
            "@type": "Offer",
            "price": "2000",
            "priceCurrency": "BDT",
            "name": "Power",
            "description": "4000 credits/month with rollover"
          },
          {
            "@type": "Offer",
            "price": "5000",
            "priceCurrency": "BDT",
            "name": "Business",
            "description": "12000 credits/month with rollover"
          }
        ]
      }
    </script>

    <title>{title}</title>
  </head>
  <body class="bg-kobi-bg text-kobi-text antialiased">
    <slot />

    <!-- Scroll-triggered fade-in animation -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1 }
      );

      document.querySelectorAll(".fade-in").forEach((el) => {
        observer.observe(el);
      });
    </script>

    <!-- i18n language toggle script -->
    <script define:vars={{ translationsJson: JSON.stringify(translations) }}>
      (function () {
        const translations = JSON.parse(translationsJson);
        const STORAGE_KEY = "kobi-lang";

        function getLang() {
          return localStorage.getItem(STORAGE_KEY) || "bn";
        }

        function setLang(lang) {
          localStorage.setItem(STORAGE_KEY, lang);
        }

        function applyTranslations(lang) {
          const t = translations[lang];
          if (!t) return;

          document.querySelectorAll("[data-i18n]").forEach((el) => {
            const key = el.getAttribute("data-i18n");
            if (key && t[key] !== undefined) {
              el.textContent = t[key];
            }
          });

          // Update html lang attribute
          document.documentElement.lang = lang === "bn" ? "bn" : "en";

          // Update toggle button labels — show the OTHER language as the label
          const labelText = lang === "bn" ? "EN" : "বাং";
          const labelEl = document.getElementById("lang-label");
          const labelMobileEl = document.getElementById("lang-label-mobile");
          if (labelEl) labelEl.textContent = labelText;
          if (labelMobileEl) labelMobileEl.textContent = labelText;
        }

        function toggleLang() {
          const current = getLang();
          const next = current === "en" ? "bn" : "en";
          setLang(next);
          applyTranslations(next);
        }

        // Apply saved language on page load
        const savedLang = getLang();
        if (savedLang !== "en") {
          applyTranslations(savedLang);
        } else {
          // English is in the HTML already, but update toggle label + html lang
          document.documentElement.lang = "en";
          const labelEl = document.getElementById("lang-label");
          const labelMobileEl = document.getElementById("lang-label-mobile");
          if (labelEl) labelEl.textContent = "বাং";
          if (labelMobileEl) labelMobileEl.textContent = "বাং";
        }

        // Bind toggle buttons
        const toggleBtn = document.getElementById("lang-toggle");
        const toggleBtnMobile = document.getElementById("lang-toggle-mobile");
        if (toggleBtn) toggleBtn.addEventListener("click", toggleLang);
        if (toggleBtnMobile) toggleBtnMobile.addEventListener("click", toggleLang);

        // MutationObserver: re-apply translations when React adds new elements with data-i18n
        const mutationObserver = new MutationObserver((mutations) => {
          const lang = getLang();
          if (lang === "en") return;
          const t = translations[lang];
          if (!t) return;

          for (const mutation of mutations) {
            for (const node of mutation.addedNodes) {
              if (node.nodeType !== Node.ELEMENT_NODE) continue;
              const el = node;
              if (el.hasAttribute && el.hasAttribute("data-i18n")) {
                const key = el.getAttribute("data-i18n");
                if (key && t[key] !== undefined) {
                  el.textContent = t[key];
                }
              }
              if (el.querySelectorAll) {
                el.querySelectorAll("[data-i18n]").forEach((child) => {
                  const key = child.getAttribute("data-i18n");
                  if (key && t[key] !== undefined) {
                    child.textContent = t[key];
                  }
                });
              }
            }
          }
        });

        mutationObserver.observe(document.body, {
          childList: true,
          subtree: true,
        });
      })();
    </script>
  </body>
</html>
